NODE_ENV=production
PORT=3000

MONGODB_URI=mongodb://root:{{ hoodly_mongo_password }}@hoodly-mongo:27017/hoodly?authSource=admin
MONGO_ROOT_PASSWORD={{ hoodly_mongo_password }}

SQLITE_PATH=/app/data/hoodly_local.db

NEO4J_URI=neo4j://hoodly-neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD={{ hoodly_neo4j_password }}
NEO4J_AUTH=neo4j/{{ hoodly_neo4j_password }}

JWT_SECRET={{ hoodly_jwt_secret }}
JWT_REFRESH_SECRET={{ hoodly_jwt_refresh_secret }}
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

OTP_SECRET={{ hoodly_otp_secret }}
GMAIL_USER={{ hoodly_gmail_user }}
GMAIL_APP_PASSWORD={{ hoodly_gmail_app_password }}

CORS_ORIGIN=https://hoodly.lennyblk.dev
